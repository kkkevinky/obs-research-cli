cmd_find() {
  require_vault
  load_config

  echo "── 搜索笔记 ──"
  echo ""
  echo "搜索方式："
  echo "  1) 按 tag"
  echo "  2) 按关键词"
  printf "你的选择 (1/2): "
  read -r mode

  local pattern=""
  case "$mode" in
    1)
      if [ ${#ALL_TAGS[@]} -eq 0 ]; then
        echo "没有配置 tag"; return 1
      fi
      echo ""
      echo "选择 tag："
      for i in "${!ALL_TAGS[@]}"; do
        echo "  $((i+1))) ${ALL_TAGS[$i]}"
      done
      printf "你的选择: "
      read -r choice
      local idx=$((choice-1))
      if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#ALL_TAGS[@]}" ]; then
        pattern="${ALL_TAGS[$idx]}"
      else
        echo "无效选择"; return 1
      fi
      ;;
    2)
      printf "输入关键词: "
      read -r pattern
      if [ -z "$pattern" ]; then
        echo "关键词不能为空"; return 1
      fi
      ;;
    *) echo "无效选择"; return 1 ;;
  esac

  echo ""
  echo "搜索结果："
  echo "────────────"

  local results=()
  while IFS= read -r line; do
    results+=("$line")
  done < <(grep -rl "$pattern" "$VAULT" --include="*.md" 2>/dev/null \
    | grep -v '/templates/' \
    | grep -v '/\.obsidian/' \
    | grep -v '/obs-research-cli/' \
    | grep -v '/obs-cli/' \
    | sort)

  if [ ${#results[@]} -eq 0 ]; then
    echo "  没有找到匹配的笔记"
    return 0
  fi

  for i in "${!results[@]}"; do
    echo "  $((i+1))) ${results[$i]#$VAULT/}"
  done

  echo ""
  printf "打开哪个？（输入编号，回车跳过）: "
  read -r open_choice
  if [ -n "$open_choice" ]; then
    local oidx=$((open_choice-1))
    if [ "$oidx" -ge 0 ] && [ "$oidx" -lt "${#results[@]}" ]; then
      open_in_obsidian "${results[$oidx]}"
    fi
  fi
}

