# ── obs init (update mode) ───────────────────────────────

write_config() {
  local folders_str tags_str
  folders_str=$(IFS=,; echo "${FOLDERS[*]}")
  tags_str=$(IFS=,; echo "${ALL_TAGS[*]}")
  cat > "$VAULT/$CONFIG_FILE" << EOF
VAULT_NAME=$VAULT_NAME
FOLDERS=$folders_str
TAGS=$tags_str
EOF
}

update_add_project() {
  printf "新项目文件夹名称: "
  read -r new_name
  new_name=$(echo "$new_name" | xargs)
  if [ -z "$new_name" ]; then
    echo "名称不能为空" >&2; return 1
  fi
  for f in "${FOLDERS[@]}"; do
    if [ "$f" = "$new_name" ]; then
      echo "文件夹 '$new_name' 已存在" >&2; return 1
    fi
  done
  mkdir -p "$VAULT/$new_name"
  FOLDERS+=("$new_name")
  write_config
  echo "✓ 已添加项目：$new_name"
}

update_add_tag() {
  printf "新 tag 名称: "
  read -r new_tag
  new_tag=$(echo "$new_tag" | xargs)
  if [ -z "$new_tag" ]; then
    echo "名称不能为空" >&2; return 1
  fi
  for t in "${ALL_TAGS[@]}"; do
    if [ "$t" = "$new_tag" ]; then
      echo "Tag '$new_tag' 已存在" >&2; return 1
    fi
  done
  ALL_TAGS+=("$new_tag")
  write_config
  echo "✓ 已添加 tag：$new_tag"
}

update_remove_tag() {
  if [ ${#ALL_TAGS[@]} -eq 0 ]; then
    echo "当前没有 tag 可以删除" >&2; return 1
  fi
  echo ""
  echo "选择要删除的 tag："
  for i in "${!ALL_TAGS[@]}"; do
    echo "  $((i+1))) ${ALL_TAGS[$i]}"
  done
  printf "你的选择: "
  read -r choice
  local idx=$((choice-1))
  if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$idx" -lt 0 ] || [ "$idx" -ge "${#ALL_TAGS[@]}" ]; then
    echo "无效选择" >&2; return 1
  fi
  local removed="${ALL_TAGS[$idx]}"
  local new_tags=()
  for i in "${!ALL_TAGS[@]}"; do
    if [ "$i" != "$idx" ]; then
      new_tags+=("${ALL_TAGS[$i]}")
    fi
  done
  ALL_TAGS=("${new_tags[@]}")
  write_config
  echo "✓ 已删除 tag：$removed"
}

# Scan vault for all tags used in notes. Case-insensitive dedup (keep first-seen casing).
# Outputs unique tags, one per line, sorted case-insensitively.
collect_vault_tags() {
  python3 - "$VAULT" << 'PYEOF' 2>/dev/null
import sys, re
from pathlib import Path

vault = sys.argv[1]
exclude = ['/.obsidian/', '/templates/', '/obs-research-cli/', '/obs-cli/']
seen = {}  # lowercase -> original casing (first seen wins)

def add(tag):
    tag = tag.strip()
    if not tag:
        return
    key = tag.lower()
    if key not in seen:
        seen[key] = tag

for md in Path(vault).rglob("*.md"):
    p = str(md)
    if any(ex in p for ex in exclude):
        continue
    try:
        content = md.read_text(encoding='utf-8', errors='ignore')
    except Exception:
        continue

    # Split frontmatter from body
    fm = ''
    body = content
    fm_match = re.match(r'^---\s*\n(.*?)\n---\s*\n', content, re.DOTALL)
    if fm_match:
        fm = fm_match.group(1)
        body = content[fm_match.end():]

    # Frontmatter: inline list  tags: [a, b]
    for m in re.finditer(r'^tag(?:s)?:\s*\[(.*?)\]', fm, re.MULTILINE):
        for t in m.group(1).split(','):
            add(t.strip().strip('"').strip("'"))
    # Frontmatter: list form
    # tags:
    #   - a
    for m in re.finditer(r'^tag(?:s)?:\s*\n((?:\s+-\s+[^\n]+\n?)+)', fm, re.MULTILINE):
        for line in m.group(1).split('\n'):
            line = line.strip()
            if line.startswith('- '):
                add(line[2:].strip().strip('"').strip("'"))
    # Frontmatter: string form  tags: foo
    for m in re.finditer(r'^tag(?:s)?:[ \t]+([^\[\s\n][^\n]*)', fm, re.MULTILINE):
        val = m.group(1).strip().strip('"').strip("'")
        if val and not val.startswith('['):
            add(val)

    # Strip code blocks and markdown links to avoid false positives
    body = re.sub(r'```.*?```', '', body, flags=re.DOTALL)
    body = re.sub(r'`[^`\n]*`', '', body)
    body = re.sub(r'\[[^\]]*\]\([^)]*\)', '', body)

    # Inline #tags
    for m in re.finditer(r'(?<![\w#])#([\w\-/]+)', body):
        t = m.group(1)
        if t.isdigit():
            continue
        if not any(c.isalpha() for c in t):
            continue
        add(t)

for t in sorted(seen.values(), key=str.lower):
    print(t)
PYEOF
}

update_sync_tags() {
  if ! command -v python3 &>/dev/null; then
    echo "错误：同步 tag 需要 python3" >&2
    return 1
  fi

  echo ""
  echo "正在扫描 vault..."
  local discovered
  discovered=$(collect_vault_tags)

  if [ -z "$discovered" ]; then
    echo "未在 vault 中发现任何 tag"
    return 0
  fi

  # Compute new tags: discovered - ALL_TAGS (case-insensitive compare)
  local existing_lc=()
  for t in "${ALL_TAGS[@]}"; do
    existing_lc+=("$(echo "$t" | tr '[:upper:]' '[:lower:]')")
  done

  local new_tags=()
  while IFS= read -r tag; do
    [ -z "$tag" ] && continue
    local tag_lc
    tag_lc=$(echo "$tag" | tr '[:upper:]' '[:lower:]')
    local found=false
    for e in "${existing_lc[@]}"; do
      if [ "$e" = "$tag_lc" ]; then found=true; break; fi
    done
    if ! $found; then
      new_tags+=("$tag")
    fi
  done <<< "$discovered"

  if [ ${#new_tags[@]} -eq 0 ]; then
    echo "✓ .obs-config 已包含 vault 中所有 tag（大小写不敏感），无需同步"
    return 0
  fi

  echo ""
  echo "发现 ${#new_tags[@]} 个新 tag："
  for i in "${!new_tags[@]}"; do
    echo "  $((i+1))) ${new_tags[$i]}"
  done
  echo ""
  printf "有要剔除的吗？（输入编号，多个用空格隔开，回车跳过）: "
  read -r drop_input

  # Filter out dropped indices
  local keep_tags=()
  if [ -n "$drop_input" ]; then
    local drop_set=" "
    for c in $drop_input; do
      if [[ "$c" =~ ^[0-9]+$ ]]; then
        drop_set+="$c "
      fi
    done
    for i in "${!new_tags[@]}"; do
      local num=$((i+1))
      if [[ "$drop_set" != *" $num "* ]]; then
        keep_tags+=("${new_tags[$i]}")
      fi
    done
  else
    keep_tags=("${new_tags[@]}")
  fi

  if [ ${#keep_tags[@]} -eq 0 ]; then
    echo "所有 tag 都被剔除，已取消"
    return 0
  fi

  echo ""
  echo "将添加以下 ${#keep_tags[@]} 个 tag 到 .obs-config："
  echo "  ${keep_tags[*]}"
  echo ""
  printf "确认？ [Y/n]: "
  read -r confirm
  case "$confirm" in
    n|N|no|No|NO)
      echo "已取消"
      return 0
      ;;
  esac

  ALL_TAGS+=("${keep_tags[@]}")
  write_config
  echo "✓ 已同步 ${#keep_tags[@]} 个 tag"
}

cmd_init_update() {
  echo "── obs 更新配置 ──"
  echo ""
  echo "当前 vault: $VAULT_NAME"
  echo "项目文件夹: ${FOLDERS[*]}"
  echo "Tags: ${ALL_TAGS[*]}"
  echo ""
  echo "可用操作："
  echo "  1) 添加新项目文件夹"
  echo "  2) 添加 tag"
  echo "  3) 删除 tag"
  echo "  4) 从 vault 同步 tag（扫描所有笔记自动发现 tag）"
  echo "  5) 退出"
  echo ""
  echo "（如需从零重新初始化，请先删除 .obs-config 后再运行 obs init）"
  echo ""
  printf "请选择 (1-5): "
  read -r choice

  case "$choice" in
    1) update_add_project ;;
    2) update_add_tag ;;
    3) update_remove_tag ;;
    4) update_sync_tags ;;
    5) return 0 ;;
    *) echo "无效选择" >&2; return 1 ;;
  esac
}

