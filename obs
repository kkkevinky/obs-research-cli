#!/bin/bash
#
# obs — Obsidian 研究笔记 CLI
# https://github.com/kkkevinky/obs-research-cli
#

set -e

# ── vault detection ──────────────────────────────────────

find_vault() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.obsidian" ]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

require_vault() {
  VAULT=$(find_vault) || {
    echo "错误：当前目录不在 Obsidian vault 中" >&2
    echo "请先 cd 到你的 vault 目录，或运行 obs init 初始化" >&2
    exit 1
  }
}

# ── config ───────────────────────────────────────────────

CONFIG_FILE=".obs-config"

read_config() {
  local key="$1"
  local config="$VAULT/$CONFIG_FILE"
  if [ -f "$config" ]; then
    grep "^${key}=" "$config" 2>/dev/null | cut -d= -f2-
  fi
}

load_config() {
  VAULT_NAME=$(read_config "VAULT_NAME")
  if [ -z "$VAULT_NAME" ]; then
    VAULT_NAME=$(basename "$VAULT")
  fi

  local folders_str
  folders_str=$(read_config "FOLDERS")
  IFS=',' read -ra FOLDERS <<< "$folders_str"

  local tags_str
  tags_str=$(read_config "TAGS")
  IFS=',' read -ra ALL_TAGS <<< "$tags_str"
}

# ── helpers ──────────────────────────────────────────────

open_in_obsidian() {
  local rel="${1#$VAULT/}"
  rel="${rel%.md}"
  local encoded="${rel// /%20}"
  encoded="${encoded//\//%2F}"
  if command -v open &>/dev/null; then
    open "obsidian://open?vault=${VAULT_NAME}&file=${encoded}"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "obsidian://open?vault=${VAULT_NAME}&file=${encoded}"
  else
    echo "提示：请手动在 Obsidian 中打开 ${rel}.md" >&2
  fi
}

pick_tags() {
  if [ ${#ALL_TAGS[@]} -eq 0 ]; then
    echo "[]"
    return
  fi

  echo "" >&2
  echo "选择 tag（输入编号，多个用空格隔开，直接回车跳过）：" >&2
  for i in "${!ALL_TAGS[@]}"; do
    printf "  %d) %s" "$((i+1))" "${ALL_TAGS[$i]}" >&2
    if (( (i+1) % 3 == 0 )); then
      echo "" >&2
    fi
  done
  echo "" >&2
  printf "你的选择: " >&2
  read -r choices

  local selected=()
  for c in $choices; do
    local idx=$((c-1))
    if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#ALL_TAGS[@]}" ]; then
      selected+=("${ALL_TAGS[$idx]}")
    fi
  done

  if [ ${#selected[@]} -eq 0 ]; then
    echo "[]"
  else
    local yaml="["
    for i in "${!selected[@]}"; do
      if [ "$i" -gt 0 ]; then yaml+=", "; fi
      yaml+="${selected[$i]}"
    done
    yaml+="]"
    echo "$yaml"
  fi
}

safe_path() {
  local dir="$1" name="$2" ext="$3"
  local path="$dir/$name$ext"
  local n=2
  while [ -f "$path" ]; do
    path="$dir/${name}_${n}${ext}"
    n=$((n+1))
  done
  echo "$path"
}

require_input() {
  local prompt="$1" result=""
  while [ -z "$result" ]; do
    printf "%s" "$prompt" >&2
    read -r result
    if [ -z "$result" ]; then
      echo "  (不能为空，请重新输入)" >&2
    fi
  done
  echo "$result"
}

pick_folder() {
  echo "" >&2
  echo "选择文件夹：" >&2
  local project_folders=()
  for f in "${FOLDERS[@]}"; do
    case "$f" in
      Literature|Concepts|templates|attachments) ;;
      *) project_folders+=("$f") ;;
    esac
  done

  for i in "${!project_folders[@]}"; do
    echo "  $((i+1))) ${project_folders[$i]}" >&2
  done
  printf "你的选择: " >&2
  read -r choice

  local idx=$((choice-1))
  if [ "$idx" -ge 0 ] && [ "$idx" -lt "${#project_folders[@]}" ]; then
    echo "${project_folders[$idx]}"
  else
    echo "无效选择" >&2
    return 1
  fi
}

# collect all vault .md files (excluding system dirs), store in MD_FILES array
collect_md_files() {
  MD_FILES=()
  while IFS= read -r f; do
    [ -n "$f" ] && MD_FILES+=("$f")
  done < <(find "$VAULT" -name "*.md" \
    -not -path "*/.obsidian/*" \
    -not -path "*/templates/*" \
    -not -path "*/obs-research-cli/*" \
    -not -path "*/obs-cli/*" \
    2>/dev/null)
}

# ── commands ─────────────────────────────────────────────

cmd_init() {
  if [ ! -d ".obsidian" ]; then
    echo "错误：当前目录不是 Obsidian vault 根目录（没有找到 .obsidian/）" >&2
    echo "请先 cd 到你的 Obsidian vault 根目录" >&2
    exit 1
  fi

  # Already initialized → enter update mode
  if [ -f "$CONFIG_FILE" ]; then
    VAULT="$PWD"
    load_config
    cmd_init_update
    return
  fi

  echo "── obs init ──"
  echo ""
  echo "初始化你的研究笔记系统。"
  echo ""

  local default_name
  default_name=$(basename "$PWD")
  printf "Vault 名称 [%s]: " "$default_name"
  read -r vault_name
  if [ -z "$vault_name" ]; then
    vault_name="$default_name"
  fi

  echo ""
  echo "你的研究项目有哪些？（用逗号分隔）"
  echo "例如：Time-Perception,Time-Discrimination"
  local projects=""
  while [ -z "$projects" ]; do
    printf "项目名称: "
    read -r projects
    if [ -z "$projects" ]; then echo "  (不能为空，请重新输入)"; fi
  done

  echo ""
  echo "常用 tag 有哪些？（用逗号分隔）"
  echo "例如：perception,discrimination,reproduction,estimation,review,todo"
  local tags=""
  while [ -z "$tags" ]; do
    printf "Tag 列表: "
    read -r tags
    if [ -z "$tags" ]; then echo "  (不能为空，请重新输入)"; fi
  done

  local all_folders="Literature,${projects},Concepts"

  echo ""
  IFS=',' read -ra folder_arr <<< "$all_folders"
  for folder in "${folder_arr[@]}"; do
    folder=$(echo "$folder" | xargs)
    mkdir -p "$folder"
    echo "  创建文件夹: $folder/"
  done
  mkdir -p templates attachments Inbox
  echo "  创建文件夹: templates/"
  echo "  创建文件夹: attachments/"
  echo "  创建文件夹: Inbox/"

  cat > "$CONFIG_FILE" << EOF
VAULT_NAME=$vault_name
FOLDERS=$all_folders
TAGS=$tags
EOF
  echo "  创建配置: $CONFIG_FILE"

  cat > "templates/literature-note.md" << 'TMPL'
---
tags: []
year:
authors:
journal:
doi:
---

## Summary / 核心发现
<!-- 2–3 sentences on the key findings / 2–3 句概括核心发现 -->

## Methods / 方法
<!-- Paradigm, participants, key variables / 实验范式、被试、关键变量 -->

## Relevance / 与我研究的关系
<!-- How does this relate to my research? / 对我的研究有什么启发？ -->

## Key concepts / 关键概念
<!-- Link related notes with `[[note name]]` / 用 `[[笔记名]]` 链接相关笔记 -->
TMPL
  echo "  创建模板: templates/literature-note.md"

  cat > "templates/research-note.md" << 'TMPL'
---
tags: []
date:
---

## Idea / 想法
<!-- Thoughts, questions, hypotheses / 灵感、问题、假设 -->

## Related literature / 相关文献
<!-- Link existing literature notes with `[[note name]]` / 用 `[[笔记名]]` 链接已有文献笔记 -->

## Next steps / 下一步
<!-- What to do next? / 接下来要做什么？ -->
TMPL
  echo "  创建模板: templates/research-note.md"

  cat > "START HERE.md" << GUIDE
