  require_vault
  load_config

  echo "── 新建文献笔记 ──"
  echo ""

  local author year title tags

  author=$(require_input "第一作者姓（如 Grondin）: ")
  year=$(require_input "年份（如 2024）: ")
  title=$(require_input "简短标题（如 Duration Review）: ")
