# ── obs bib ──────────────────────────────────────────────

cmd_bib() {
  require_vault
  load_config

  local doi="$1"
  if [ -z "$doi" ]; then
    printf "输入 DOI（如 10.1016/j.tics.2023.01.001）: "
    read -r doi
  fi

  if [ -z "$doi" ]; then
    echo "DOI 不能为空" >&2
    return 1
  fi

  # clean doi: remove URL prefix if present
  doi="${doi#https://doi.org/}"
  doi="${doi#http://doi.org/}"
  doi="${doi#doi:}"

  echo "正在获取文献信息..."

  local json
  json=$(curl -s -L -H "Accept: application/json" "https://api.crossref.org/works/${doi}" 2>/dev/null)

  if [ -z "$json" ] || echo "$json" | grep -q '"status":"failed"'; then
    echo "错误：无法获取 DOI $doi 的信息，请检查 DOI 是否正确" >&2
    return 1
  fi

  # parse with python3 (available on macOS)
  local parsed
  parsed=$(python3 -c "
import json, sys
try:
    data = json.loads(sys.stdin.read())
    msg = data.get('message', {})

    # title
    titles = msg.get('title', [])
    title = titles[0] if titles else 'Untitled'

    # authors
    authors_list = msg.get('author', [])
    if authors_list:
        first = authors_list[0].get('family', '')
        if len(authors_list) > 1:
            authors_str = first + ' et al.'
        else:
            authors_str = first
    else:
        authors_str = 'Unknown'
    first_author = authors_list[0].get('family', 'Unknown') if authors_list else 'Unknown'

    # year
    date_parts = msg.get('published-print', msg.get('published-online', msg.get('created', {})))
    parts = date_parts.get('date-parts', [[0]])[0] if date_parts else [0]
    year = str(parts[0]) if parts else 'Unknown'

    # journal
    journals = msg.get('container-title', [])
    journal = journals[0] if journals else ''

    # abstract
    abstract = msg.get('abstract', '')
    # clean HTML tags from abstract
    import re
    abstract = re.sub(r'<[^>]+>', '', abstract)
    if len(abstract) > 500:
        abstract = abstract[:500] + '...'

    print(f'FIRST_AUTHOR={first_author}')
    print(f'AUTHORS={authors_str}')
    print(f'YEAR={year}')
    print(f'TITLE={title}')
    print(f'JOURNAL={journal}')
    print(f'ABSTRACT={abstract}')
except Exception as e:
    print(f'ERROR={e}', file=sys.stderr)
    sys.exit(1)
" <<< "$json")

  if [ $? -ne 0 ]; then
    echo "错误：解析文献数据失败" >&2
    return 1
  fi

  # extract fields
  local first_author authors year title journal abstract
  first_author=$(echo "$parsed" | grep "^FIRST_AUTHOR=" | cut -d= -f2-)
  authors=$(echo "$parsed" | grep "^AUTHORS=" | cut -d= -f2-)
  year=$(echo "$parsed" | grep "^YEAR=" | cut -d= -f2-)
  title=$(echo "$parsed" | grep "^TITLE=" | cut -d= -f2-)
  journal=$(echo "$parsed" | grep "^JOURNAL=" | cut -d= -f2-)
  abstract=$(echo "$parsed" | grep "^ABSTRACT=" | cut -d= -f2-)

  echo ""
  echo "  标题:   $title"
  echo "  作者:   $authors"
  echo "  年份:   $year"
  echo "  期刊:   $journal"
  echo ""

  # generate short title (first 5 words)
  local short_title
  short_title=$(echo "$title" | awk '{for(i=1;i<=5&&i<=NF;i++) printf "%s ", $i; print ""}' | sed 's/ *$//')

  local tags
  tags=$(pick_tags)

  local filename="$first_author $year - $short_title"
  local filepath
  filepath=$(safe_path "$VAULT/Literature" "$filename" ".md")

  cat > "$filepath" << HEREDOC
---
tags: $tags
year: $year
authors: $authors
journal: $journal
doi: $doi
---

## Abstract / 摘要

$abstract

## Summary / 核心发现
<!-- 2–3 sentences on the key findings / 2–3 句概括核心发现 -->

## Methods / 方法
<!-- Paradigm, participants, key variables / 实验范式、被试、关键变量 -->

## Relevance / 与我研究的关系
<!-- How does this relate to my research? / 对我的研究有什么启发？ -->

## Key concepts / 关键概念
<!-- Link related notes with \`[[note name]]\` / 用 \`[[笔记名]]\` 链接相关笔记 -->
HEREDOC

  echo "✓ 已创建: ${filepath#$VAULT/}"
  open_in_obsidian "$filepath"
}

# ── obs status ───────────────────────────────────────────

cmd_status() {
  require_vault
  load_config

  echo "── 研究仪表盘 ──"
  echo ""

  collect_md_files

  local total=${#MD_FILES[@]}
  echo "  笔记总数: $total"
  echo ""

  # count per folder
  echo "  各文件夹："
  for f in "${FOLDERS[@]}"; do
    local count=0
    for md in "${MD_FILES[@]}"; do
      if [[ "$md" == "$VAULT/$f/"* ]]; then
        count=$((count+1))
      fi
    done
    if [ "$count" -gt 0 ]; then
      echo "    $f/  $count 篇"
    fi
  done

  # inbox
  local inbox_count=0
  for md in "${MD_FILES[@]}"; do
    if [[ "$md" == "$VAULT/Inbox/"* ]]; then
      inbox_count=$((inbox_count+1))
    fi
  done
  if [ "$inbox_count" -gt 0 ]; then
    echo "    Inbox/  $inbox_count 篇"
  fi
  echo ""

  # todos
  local todo_count=0
  local todo_files=()
  for md in "${MD_FILES[@]}"; do
    if grep -ql "todo\|TODO\|#todo" "$md" 2>/dev/null; then
      todo_count=$((todo_count+1))
      todo_files+=("$md")
    fi
  done
  if [ "$todo_count" -gt 0 ]; then
    echo "  待处理 (#todo): $todo_count 篇"
    for tf in "${todo_files[@]:0:5}"; do
      echo "    - ${tf#$VAULT/}"
    done
    if [ "$todo_count" -gt 5 ]; then
      echo "    ... 还有 $((todo_count-5)) 篇"
    fi
    echo ""
  fi

  # orphan notes (no [[ links to other notes, and no other notes link to them)
  echo "  孤立笔记（没有任何 [[链接]] 的）："
  local orphan_count=0
  for md in "${MD_FILES[@]}"; do
    local basename_no_ext
    basename_no_ext=$(basename "$md" .md)
    # check if this note contains any [[ links
    local has_outgoing=false
    if grep -q '\[\[' "$md" 2>/dev/null; then
      has_outgoing=true
    fi
    # check if any other note links to this one
    local has_incoming=false
    if grep -rl "\[\[$basename_no_ext" "$VAULT" --include="*.md" 2>/dev/null \
      | grep -v "$md" | grep -q .; then
      has_incoming=true
    fi
    if [ "$has_outgoing" = false ] && [ "$has_incoming" = false ]; then
      # skip system files
      case "$basename_no_ext" in
        "START HERE") continue ;;
      esac
      echo "    - ${md#$VAULT/}"
      orphan_count=$((orphan_count+1))
      if [ "$orphan_count" -ge 10 ]; then
        echo "    ... (只显示前 10 个)"
        break
      fi
    fi
  done
  if [ "$orphan_count" -eq 0 ]; then
    echo "    无"
  fi

  echo ""

  # recent activity
  echo "  最近 3 天活跃："
  local three_days_ago
  if date -v-3d &>/dev/null; then
    three_days_ago=$(date -v-3d +%s)
  else
    three_days_ago=$(date -d "3 days ago" +%s 2>/dev/null || echo 0)
  fi
  local recent_count=0
  for md in "${MD_FILES[@]}"; do
    local mtime
    if stat -f "%m" "$md" &>/dev/null; then
      mtime=$(stat -f "%m" "$md")
    else
      mtime=$(stat -c "%Y" "$md" 2>/dev/null || echo 0)
    fi
    if [ "$mtime" -ge "$three_days_ago" ]; then
      recent_count=$((recent_count+1))
    fi
  done
  echo "    $recent_count 篇笔记有更新"
}

# ── obs moc ──────────────────────────────────────────────

cmd_moc() {
  require_vault
  load_config

  local tag="$1"
  if [ -z "$tag" ]; then
    printf "为哪个 tag 生成索引？: "
    read -r tag
  fi
  if [ -z "$tag" ]; then
    echo "tag 不能为空" >&2
    return 1
  fi

  echo "正在扫描 #$tag 笔记..."

  local matches=()
  while IFS= read -r line; do
    matches+=("$line")
  done < <(grep -rl "$tag" "$VAULT" --include="*.md" 2>/dev/null \
    | grep -v '/templates/' \
    | grep -v '/\.obsidian/' \
    | grep -v '/obs-research-cli/' \
    | sort)

  if [ ${#matches[@]} -eq 0 ]; then
    echo "没有找到包含 #$tag 的笔记"
    return 0
  fi

  local today
  today=$(date +%Y-%m-%d)
  local moc_path
  moc_path=$(safe_path "$VAULT" "MOC - $tag" ".md")

  # build MOC content
  {
    echo "---"
    echo "tags: [moc, $tag]"
    echo "date: $today"
    echo "---"
    echo ""
    echo "# $tag 索引"
    echo ""
    local match_count=${#matches[@]}
    echo "自动生成于 ${today}, 共 ${match_count} 篇相关笔记。"
    echo ""

    # group by folder
    local current_folder=""
    for md in "${matches[@]}"; do
      local rel="${md#$VAULT/}"
      local folder
      folder=$(dirname "$rel")
      if [ "$folder" = "." ]; then folder="根目录"; fi

      if [ "$folder" != "$current_folder" ]; then
        current_folder="$folder"
        echo "## $folder"
        echo ""
      fi

      local name
      name=$(basename "$md" .md)

      # try to extract the first content line under the Summary section
      local summary=""
      summary=$(grep -m1 "^## Summary" -A1 "$md" 2>/dev/null | tail -1 | sed 's/<!--.*-->//')
      if [ -z "$summary" ] || [ "$summary" = "---" ] || [[ "$summary" =~ ^[[:space:]]*$ ]]; then
        summary=""
      fi

      if [ -n "$summary" ] && [ "$summary" != "" ]; then
        echo "- [[$name]] — $summary"
      else
        echo "- [[$name]]"
      fi
    done
    echo ""
  } > "$moc_path"

  echo ""
  echo "✓ 已生成: ${moc_path#$VAULT/}"
  echo "  包含 ${#matches[@]} 篇笔记"
  open_in_obsidian "$moc_path"
}

# ── obs links ────────────────────────────────────────────

cmd_links() {
  require_vault
  load_config

  echo "── 发现缺失的链接 ──"
  echo ""

  # collect all concept names (from Concepts/ folder and from existing [[ ]] links)
  local concepts=()

  # from Concepts/ folder
  if [ -d "$VAULT/Concepts" ]; then
    while IFS= read -r f; do
      local name
      name=$(basename "$f" .md)
      concepts+=("$name")
    done < <(find "$VAULT/Concepts" -name "*.md" 2>/dev/null)
  fi

  # from all [[ ]] links across vault
  collect_md_files
  while IFS= read -r link; do
    [ -n "$link" ] && concepts+=("$link")
  done < <(grep -oh '\[\[[^]|]*' "$VAULT"/*.md "$VAULT"/**/*.md 2>/dev/null \
    | sed 's/\[\[//' | sort -u)

  # deduplicate
  local unique_concepts=()
  local seen=""
  for c in "${concepts[@]}"; do
    if [[ "$seen" != *"|$c|"* ]]; then
      unique_concepts+=("$c")
      seen+="|$c|"
    fi
  done

  if [ ${#unique_concepts[@]} -eq 0 ]; then
    echo "  还没有概念可以检查（先创建一些笔记和概念卡片）"
    return 0
  fi

  echo "  检查 ${#unique_concepts[@]} 个概念..."
  echo ""

  local found=0
  for concept in "${unique_concepts[@]}"; do
    # skip very short concept names (likely false positives)
    if [ ${#concept} -lt 3 ]; then continue; fi

    for md in "${MD_FILES[@]}"; do
      # skip the concept's own file
      local bn
      bn=$(basename "$md" .md)
      if [ "$bn" = "$concept" ]; then continue; fi

      # check if file mentions the concept but doesn't link it
      if grep -q "$concept" "$md" 2>/dev/null; then
        if ! grep -q "\[\[$concept" "$md" 2>/dev/null; then
          echo "  ${md#$VAULT/}"
          echo "    提到了 \"$concept\" 但没有链接 → 建议改为 [[$concept]]"
          echo ""
          found=$((found+1))
          if [ "$found" -ge 20 ]; then
            echo "  ... 只显示前 20 个建议"
            return 0
          fi
        fi
      fi
    done
  done

  if [ "$found" -eq 0 ]; then
    echo "  所有概念都已正确链接！"
  fi
}

